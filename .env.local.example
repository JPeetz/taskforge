# TaskForge — Supabase Configuration
# Copy this to .env.local and fill in your credentials.
# NEVER commit .env.local to git.

# Supabase Project URL (from Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://oltlnbxchdnavocpqgyc.supabase.co"

# Supabase Anon/Public Key (safe for client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# Supabase Service Role Key (SERVER-SIDE ONLY — NEVER expose to client)
# Used by the waitlist API route for admin operations
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"
